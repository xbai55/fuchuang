# ============================================
# 反诈预警系统 - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置
# ============================================

# --------------------------------------------
# LLM API 配置 (必填)
# --------------------------------------------

# 方式1: 通用 LLM 配置 (推荐)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-omni-flash

# 方式2: Kimi (Moonshot) 专用配置
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# 方式3: OpenAI 配置
# OPENAI_API_KEY=your_openai_api_key_here

# 可用模型:
# - Kimi: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# - OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo

# --------------------------------------------
# 安全配置 (必填)
# --------------------------------------------
SECRET_KEY=your-secret-key-here-change-in-production

# --------------------------------------------
# 数据库配置 (可选，默认使用 SQLite)
# --------------------------------------------
# DATABASE_URL=sqlite:///./fraud_detection.db

# --------------------------------------------
# RAG / ChromaDB 配置 (可选)
# --------------------------------------------
# CHROMA_DB_PATH=./chroma_db

# --------------------------------------------
# 应用环境 (可选)
# --------------------------------------------
ENV=development
# ENV=production

# --------------------------------------------
# CORS 配置 (生产环境必填)
# --------------------------------------------
# ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# --------------------------------------------
# Guardian notification provider
# Keep the workflow interface, then bind a concrete provider later
# Suggested future options: PushPlus / WxPusher / SMS gateway
# --------------------------------------------
# GUARDIAN_NOTIFY_PROVIDER=pending_provider