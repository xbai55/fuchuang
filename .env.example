# ============================================
# 运行环境变量模板
# 复制为 .env 后填写真实值
# ============================================

# --------------------------------------------
# LLM API
# 使用统一的 OpenAI-compatible 配置
# 默认推荐阿里 DashScope 兼容接口
# --------------------------------------------
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-omni-flash

# 本地 Ollama 兼容接口示例：
# LLM_API_KEY=dummy
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=gemma4:e2b

# --------------------------------------------
# 认证
# --------------------------------------------
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# 应用模式
# flash: 低延迟单轮模式
# pro: LangGraph 完整工作流模式
# --------------------------------------------
ENV=development
MODEL_MODE=flash

# --------------------------------------------
# 数据库
# --------------------------------------------
DATABASE_URL=sqlite:///./fraud_detection.db

# 可选：LangGraph / PostgreSQL checkpointer 持久化
# PGDATABASE_URL=postgresql://user:password@localhost:5432/fraud_detection

# 可选：生产环境 CORS
# ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.example

# --------------------------------------------
# 主 RAG
# RAG_INDEX_BACKEND 只控制主知识库后端
# 可选值：tfidf | hybrid | sentence-transformer
# --------------------------------------------
RAG_AUTO_BUILD=true
RAG_FORCE_REBUILD=false
RAG_CONFIG_PATH=config/rag.yaml
RAG_INDEX_BACKEND=hybrid
FAST_WARNING_RULES_PATH=config/fast_warning_rules.json

# 可选：快速前期预警 RAG 超时阈值
# FAST_EARLY_WARNING_RAG_TIMEOUT_SEC=1.4

# --------------------------------------------
# 官方外部案例自动同步
# 使用 config/external_case_sources.yaml
# --------------------------------------------
EXTERNAL_CASE_SYNC_ENABLED=true
EXTERNAL_CASE_SYNC_INTERVAL_SECONDS=900
EXTERNAL_CASE_SYNC_CONFIG=config/external_case_sources.yaml

# --------------------------------------------
# 启动预热
# 用于降低多模态、工作流 LLM、fast RAG 的冷启动成本
# --------------------------------------------
MODEL_WARMUP_ENABLED=true
LLM_WARMUP_ENABLED=true
MODEL_WARMUP_STARTUP_TIMEOUT=3
MODEL_WARMUP_LLM_TIMEOUT=15

# --------------------------------------------
# OCR
# --------------------------------------------
OCR_ENABLE_MKLDNN=false
OCR_CPU_THREADS=4

# --------------------------------------------
# 未来可选的通知服务商绑定
# 当前仓库仅保留接口与占位工作流
# --------------------------------------------
# GUARDIAN_NOTIFY_PROVIDER=pending_provider
